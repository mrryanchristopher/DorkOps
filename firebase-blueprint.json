{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and usage tracking",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "User ID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        },
        "isPro": {
          "type": "boolean",
          "description": "Whether the user has a Pro subscription"
        },
        "dailySearches": {
          "type": "number",
          "description": "Number of searches performed today"
        },
        "lastSearchDate": {
          "type": "string",
          "description": "Date of the last search (YYYY-MM-DD)"
        }
      },
      "required": ["uid", "email", "isPro", "dailySearches", "lastSearchDate"]
    },
    "SavedDork": {
      "title": "Saved Dork",
      "description": "A Google Dork saved by a user",
      "type": "object",
      "properties": {
        "dork": {
          "type": "string",
          "description": "The actual Google Dork string"
        },
        "intent": {
          "type": "string",
          "description": "The original search intent that generated this dork"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO 8601 timestamp of when it was saved"
        }
      },
      "required": ["dork", "intent", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and usage limits"
    },
    "/users/{userId}/savedDorks/{dorkId}": {
      "schema": {
        "$ref": "#/entities/SavedDork"
      },
      "description": "Stores dorks saved by the user"
    }
  }
}
